{
  "name": "casella",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm -F @casella/db generate",
    "db:migrate": "pnpm -F @casella/db migrate",
    "db:studio": "pnpm -F @casella/db studio"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0"
  }
}
