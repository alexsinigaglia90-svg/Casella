{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "Agent",
      "TodoWrite"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo *)",
      "Edit(/etc/**)",
      "Edit(~/.ssh/**)",
      "Edit(~/.gnupg/**)",
      "Write(/etc/**)",
      "Write(~/.ssh/**)",
      "Write(~/.gnupg/**)"
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
