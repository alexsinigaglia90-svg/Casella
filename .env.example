# ---- Database (lokaal via Supabase CLI) ----
# Run `pnpm db:up` to start local Supabase; this is its default URL.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# ---- Auth.js ----
# Generate with: npx auth secret  (or: openssl rand -base64 32)
AUTH_SECRET=""

# Canonical URL where the app runs. Locally: http://localhost:3000
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ---- Microsoft Entra ID (dev app registration) ----
# See README § "Entra ID dev setup" for how to generate these values.
AUTH_MICROSOFT_ENTRA_ID_ID=""            # Application (client) ID
AUTH_MICROSOFT_ENTRA_ID_SECRET=""        # Client secret "Value" (not the Secret ID)
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""        # Directory (tenant) ID (UUID)

# ---- Entra security groups (role mapping) ----
ENTRA_ADMIN_GROUP_ID=""                  # Object ID of Casella-Admins group
ENTRA_EMPLOYEE_GROUP_ID=""               # Object ID of Casella-Employees group

# ---- Mapbox (not used in Fase 0; required from Fase 1 for km calc) ----
MAPBOX_ACCESS_TOKEN=""

# ---- SMTP (not used in Fase 0; required from Fase 1 for notifications) ----
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@ascentra.nl"

# ---- Nmbrs (not used in Fase 0; required from Fase 1 for payroll sync) ----
NMBRS_API_DOMAIN=""
NMBRS_API_TOKEN=""
